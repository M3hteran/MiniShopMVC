@using MiniShopMVC.Models
@model MiniShopMVC.Models.Product
<div class="row justify-content-center">
	<div class="col-md-5">
		<div class="card shadow">
			<div class="card-header bg-success text-white">
				<h4 class="mb-0">Yeni Ürün Ekle</h4>
				<div class="card-body">
					<form asp-action="Create" method="post" enctype="multipart/form-data">
						<div class="mb-3">
							<label>Ürün Adı:</label>
							<input asp-for="Name" class="form-control" />
							<span asp-validation-for="Name" class="text-bg-danger"></span>
						</div>

						<div class="mb-3">
							<label>Fiyat:</label>
							<input asp-for="Price" class="form-control" />
							<span asp-validation-for="Price" class="text-bg-danger"></span>
						</div>

						<div class="mb-3">
							<label>Açıklama:</label>
							<textarea asp-for="Description" class="form-control"></textarea>
							<span asp-validation-for="Description" class="text-bg-danger"></span>
						</div>

						<div class="mb-3">
							<label>ResimUrl</label>
							<input asp-for="ImageUrl" class="form-control" />
							<span asp-validation-for="ImageUrl" class="text-bg-danger"></span>
						</div>

						<div class="mb-3">
							<label>Kategori</label>
							<select asp-for="CategoryId" class="form-control">
								@foreach (var category in ViewBag.Categories)
								{
									<option value="@category.Id">@category.Name</option>
								}
							</select>
							<span asp-validation-for="CategoryId" class="text-danger"></span>
						</div>

						<div class="mb-3">
							<label asp-for="Stock" class="form-label"></label>
							<input asp-for="Stock" class="form-control" />
							<span asp-validation-for="Stock" class="text-bg-danger"></span>
						</div>

						<div class="mb-3">
							<label class="form-label">Ürün Resmi</label>
							<input type="file" name="imageFile" class="form-control" accept="image/*"/>
						</div>

						<div class="d-flex justify-content-end gap-2">
							<a asp-action="Index" class="btn btn-secondary"> Vazgeç</a>
							<button class="btn btn-primary">Kaydet</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}







