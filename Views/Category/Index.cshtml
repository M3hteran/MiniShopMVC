@model List<MiniShopMVC.Models.Category>


<div class="d-flex justify-content-between align-items-center mb-4">
	<h2 class="fw-bold">Kategoriler</h2>
	<a asp-action="Create" class="btn btn-primary">+ Yeni Kategori</a>
</div>

<table class="table table-bordered table-hover">
	<thead>
		<tr>
			<th>Sıra Numarası</th>
			<th>Kategori Adı</th>
			<th>İşlemler</th>
			<th>Silme</th>
		</tr>
	</thead>

	<tbody>
		@foreach (var category in Model)
		{
			<tr>
				<td>@category.Id</td>
				<td>@category.Name</td>
				<td><a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-warning btn-sm">Düzenle</a></td>
				<td><a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-danger btn-sm">Sil</a></td>
			</tr>
		}
	</tbody>

</table>